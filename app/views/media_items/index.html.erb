<div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">My Collection</h1>
    <%= link_to "Add New Item", new_media_item_path, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
  </div>

  <%# FILTER CODE %>
  <div class="mb-8 flex items-center flex-wrap gap-2">
    <span class="text-sm font-medium text-gray-700 mr-2">Filter by:</span>

    <%= link_to "All", media_items_path, class: "px-3 py-1 text-sm font-semibold rounded-full #{params[:category_id].blank? ? 'bg-indigo-600 text-white' : 'bg-gray-200 text-gray-800 hover:bg-gray-300'}" %>

    <% @categories.each do |category| %>
      <% is_active = params[:category_id].to_s == category.id.to_s %>
      <%= link_to category.name, media_items_path(category_id: category.id), class: "px-3 py-1 text-sm font-semibold rounded-full #{is_active ? 'bg-indigo-600 text-white' : 'bg-gray-200 text-gray-800 hover:bg-gray-300'}" %>
    <% end %>
  </div>

  <% if notice.present? %>
    <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-6 rounded-md" role="alert">
      <p class="font-bold">Success</p>
      <p><%= notice %></p>
    </div>
  <% end %>

  <%= turbo_frame_tag "results" do %>
    <% if @media_items.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        
        <% @media_items.each do |media_item| %>
          
          <div class="bg-white rounded-lg shadow-lg overflow-hidden flex hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
            
            <div class="w-1/3 flex-shrink-0">
              <% if media_item.cover_image.attached? %>
                <%= image_tag media_item.cover_image.variant(resize_to_fill: [400, 600]), class: "w-full h-full object-cover" %>
              <% else %>
                <div class="w-full h-full bg-gray-200 flex items-center justify-center p-2 text-center">
                  
                  <span class="text-gray-400 text-xs ml-2">No Image</span>
                </div>
              <% end %>
            </div>
 
            <div class="w-2/3 p-4 flex flex-col justify-between">
 
              <div>
                <p class="text-sm font-semibold text-indigo-600 uppercase tracking-wider"><%= media_item.category.name %></p>
                <h2 class="text-xl font-bold text-gray-800 mt-1 truncate" title="<%= media_item.title %>">
                  <%# NEW: Added data-turbo-frame attribute to escape the frame %>
                  <%= link_to media_item.title, media_item, data: { turbo_frame: "_top" }, class: "hover:text-indigo-700" %>
                </h2>
                
                <div class="flex items-center flex-wrap gap-2 mt-2">
                  <span class="inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-800">
                    <%= media_item.status %>
                  </span>
                  <% if media_item.rating.present? %>
                    <span class="inline-flex items-center rounded-full bg-yellow-100 px-2 py-0.5 text-xs font-medium text-yellow-800">
                      ⭐ <%= media_item.rating %> / 10
                    </span>
                  <% end %>
                </div>
                
                <p class="text-gray-600 text-sm leading-relaxed mt-3">
                  <%= truncate(media_item.description, length: 80) %>
                </p>
 
                <% if media_item.chapters_read.present? %>
                  <div class="mt-4">
                    <div class="flex justify-between text-xs font-medium text-gray-500">
                      <span>Chapters</span>
                      <span>
                        <%= media_item.chapters_read %> / <%= media_item.total_chapters.presence || '?' %>
                      </span>
                    </div>
                    <% progress = media_item.total_chapters.to_i > 0 ? (media_item.chapters_read.to_f / media_item.total_chapters.to_f) * 100 : 0 %>
                    <div class="w-full bg-gray-200 rounded-full h-1.5 mt-1">
                      <div class="bg-blue-600 h-1.5 rounded-full" style="width: <%= progress %>%"></div>
                    </div>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
        
      </div>
    <% else %>
      <div class="text-center py-16 px-6 bg-white rounded-lg shadow-md">
        <h3 class="text-xl font-semibold text-gray-800">No results found.</h3>
        <p class="text-gray-500 mt-2">Try adjusting your search or filter.</p>
      </div>
    <% end %>
  <% end %>
</div>
