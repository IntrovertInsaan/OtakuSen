<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <%# The card background now uses bg-base-100, which adapts to the current theme %>
  <div class="bg-base-100 rounded-lg shadow-xl p-6 md:p-8">
    <%# The header text now uses text-base-content, the default text color for the theme %>
    <h2 class="text-3xl font-bold tracking-tight text-base-content text-center mb-6">Log in</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="space-y-6">
        <div>
          <%# The form label text uses text-base-content %>
          <%= f.label :email, class: "block text-sm font-medium leading-6 text-base-content" %>
          <div class="mt-2">
            <%# The input field now uses DaisyUI's "input" and "input-bordered" classes for consistent styling %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
          </div>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium leading-6 text-base-content" %>
          <div class="mt-2">
            <%= f.password_field :password, autocomplete: "current-password", class: "input input-bordered w-full" %>
          </div>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="form-control">
            <label class="label cursor-pointer justify-start gap-4">
              <%# The checkbox now uses DaisyUI's "checkbox" and "checkbox-primary" classes %>
              <%= f.check_box :remember_me, class: "checkbox checkbox-primary" %>
              <span class="label-text"><%= f.label :remember_me %></span> 
            </label>
          </div>
        <% end %>

        <div>
          <%# The submit button now uses "btn" and "btn-primary" to adopt the theme's primary button style %>
          <%= f.submit "Log in", class: "btn btn-primary w-full" %>
        </div>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
