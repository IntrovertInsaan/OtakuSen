<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

  <!-- Thread Info -->
  <h1 class="text-3xl font-bold text-gray-100 mb-2"><%= @forum_thread.title %></h1>
  <p class="text-gray-400 mb-8">
    Started by <%= @forum_thread.user&.username || "[Deleted User]" %>
  </p>

  <!-- Messages Section -->
  <h3 class="text-2xl font-bold text-gray-100 mb-4">Messages</h3>
  <div id="forum_posts" class="space-y-4 max-h-[32rem] overflow-y-auto" 
       data-controller="chat-scroll"
       data-chat-scroll-behavior-value="smooth">
    <%= turbo_stream_from @forum_thread, "forum_posts" %>

    <%= render @forum_thread.forum_posts.where.not(id: nil), current_user: current_user %>
  </div>

  <!-- Reply Form -->
  <div class="mt-8">
    <h3 class="text-xl font-bold text-gray-100 mb-4">Post a Reply</h3>
    <%= form_with model: [@forum_thread, ForumPost.new], class: "space-y-4", data: { controller: "reset-form", action: "turbo:submit-end->reset-form#reset" } do |f| %>
      <div>
        <%= f.rich_text_area :content,
            class: "w-full min-h-[120px] rounded-lg border border-gray-600 bg-gray-700 text-gray-100 p-3 shadow-sm focus:border-indigo-400 focus:ring-indigo-400",
            placeholder: "Type your message..." %>
      </div>
      <div class="flex justify-end">
        <%= f.submit "Send", class: "btn btn-primary px-6 py-2" %>
      </div>
    <% end %>
  </div>
</div>
