<div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-base-content tracking-tight"><%= @page_title %></h1>
    <div class="flex items-center gap-4">
      <%= link_to "Add New Item", new_media_item_path, class: "btn btn-primary" %>
      <div class="btn-group">
        <%= link_to icon("squares-2x2", class: "h-5 w-5"), url_for(params.to_unsafe_h.merge(view: 'grid')), class: "btn btn-sm #{params[:view] != 'list' ? 'btn-primary' : 'btn-ghost'}" %>
        <%= link_to icon("bars-3", class: "h-5 w-5"), url_for(params.to_unsafe_h.merge(view: 'list')), class: "btn btn-sm #{params[:view] == 'list' ? 'btn-primary' : 'btn-ghost'}" %>
      </div>
    </div>
  </div>

  <%= render(FilterBarComponent.new(path: ->(p={}) { favorites_media_items_path(p) }, categories: @categories, tags: @tags, current_params: params.to_unsafe_h.slice(:search, :tag, :view, :category_id, :sort))) %>

  <%= render 'media_items/collection', items: @media_items, pagy_instance: @pagy, empty_message: "No favorites found." %>
</div>
