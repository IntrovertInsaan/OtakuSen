<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <%# The header text now uses the theme's default text color %>
  <h1 class="text-3xl font-bold tracking-tight text-base-content mb-8">My Dashboard</h1>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    <%# The stat cards now use DaisyUI's "card" and "stat" components for a consistent, themed look %>
    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <div class="stat">
          <div class="stat-title">Total Items</div>
          <div class="stat-value"><%= @total_items %></div>
          <div class="stat-actions">
            <%= link_to "View Public Profile →", profile_path(current_user), 
                  class: "link link-primary link-hover text-sm",
                  target: "_blank" %>
          </div>
        </div>
      </div>
    </div>

    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h2 class="card-title">By Category</h2>
        <ul class="space-y-2 mt-4">
          <% @items_by_category.each do |name, count| %>
            <li class="flex justify-between items-center">
              <span class="text-base-content"><%= name %></span>
              <%# The count badges now use the "badge" and "badge-primary" classes %>
              <div class="badge badge-primary"><%= count %></div>
            </li>
          <% end %>
        </ul>
      </div>
    </div>

    <div class="card bg-base-100 shadow-xl">
      <div class="card-body">
        <h2 class="card-title">By Status</h2>
        <ul class="space-y-2 mt-4">
          <% @items_by_status.each do |name, count| %>
            <li class="flex justify-between items-center">
              <span class="text-base-content"><%= name %></span>
              <%# The count badges now use the "badge" and "badge-secondary" classes %>
              <div class="badge badge-secondary"><%= count %></div>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
    
    <%# The chart card now also uses the "card" component style %>
    <div class="card bg-base-100 shadow-xl md:col-span-3" data-controller="pie-chart">
      <div class="card-body">
        <div class="flex justify-between items-center mb-4">
          <h2 class="card-title">Collection Stats</h2>
          
          <%# The switch buttons now use DaisyUI's "btn-group" for a cleaner look %>
          <div class="btn-group">
            <button data-action="click->pie-chart#showStatus" data-pie-chart-target="switchButton" class="btn btn-sm btn-active">
              By Status
            </button>
            <button data-action="click->pie-chart#showCategory" data-pie-chart-target="switchButton" class="btn btn-sm">
              By Category
            </button>
          </div>
        </div>
        
        <div class="h-96">
          <canvas data-pie-chart-target="canvas"
                  data-status-data="<%= @items_by_status.to_json %>"
                  data-category-data="<%= @items_by_category.to_json %>">
          </canvas>
        </div>
      </div>
    </div>

  </div>
</div>
