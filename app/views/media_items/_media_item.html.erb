<div id="<%= dom_id(media_item) %>" class="bg-base-100 rounded-lg shadow-lg overflow-hidden flex hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
  <%# bg-white → bg-base-100 so it matches current DaisyUI theme %>
  
  <div class="w-1/3 flex-shrink-0">
    <% if media_item.cover_image.attached? %>
      <%= image_tag media_item.cover_image.variant(resize_to_fill: [400, 600]), class: "w-full h-full object-cover" %>
    <% else %>
      <div class="w-full h-full bg-base-200 flex items-center justify-center p-2 text-center">
        <%# bg-gray-200 → bg-base-200 for neutral theme-aware background %>
        <span class="text-base-content/50 text-xs ml-2">No Image</span>
        <%# text-gray-400 → text-base-content/50 for muted text in theme %>
      </div>
    <% end %>
  </div>

  <div class="w-2/3 p-4 flex flex-col justify-between">

    <div>
      <p class="text-sm font-semibold text-primary uppercase tracking-wider">
        <%# text-indigo-600 → text-primary for theme-based primary accent %>
        <%= media_item.category.name %>
      </p>

      <h2 class="text-xl font-bold text-base-content mt-1 truncate" title="<%= media_item.title %>">
        <%# text-gray-800 → text-base-content for readable themed text %>
        <%= link_to media_item.title, media_item, data: { turbo_frame: "_top" }, class: "hover:text-primary" %>
        <%# hover:text-indigo-700 → hover:text-primary to match theme highlight %>
      </h2>
      
      <div class="flex items-center flex-wrap gap-2 mt-2">
        <span class="inline-flex items-center rounded-full bg-primary/20 px-2 py-0.5 text-xs font-medium text-primary">
          <%# bg-blue-100 → bg-primary/20, text-blue-800 → text-primary for status %>
          <%= media_item.status %>
        </span>
        <% if media_item.rating.present? %>
          <span class="inline-flex items-center rounded-full bg-warning/20 px-2 py-0.5 text-xs font-medium text-warning">
            <%# bg-yellow-100 → bg-warning/20, text-yellow-800 → text-warning for rating %>
            ⭐ <%= media_item.rating %> / 10
          </span>
        <% end %>
      </div>
      
      <p class="text-base-content/70 text-sm leading-relaxed mt-3">
        <%# text-gray-600 → text-base-content/70 for slightly muted text %>
        <%= truncate(media_item.description, length: 80) %>
      </p>

      <% if media_item.chapters_read.present? %>
        <div class="mt-4">
          <div class="flex justify-between items-center text-xs font-medium text-base-content/60">
            <%# text-gray-500 → text-base-content/60 for subtle info text %>
            <span>Chapters</span>
            <div class="flex items-center gap-2">
              <% if user_signed_in? && current_user == media_item.user %>
                <%= button_to "-", decrement_chapter_media_item_path(media_item), method: :patch,
                    class: "flex items-center justify-center h-5 w-5 rounded-full bg-base-300 text-base-content/70 hover:bg-base-200 transition" %>
                <%# bg-gray-200 → bg-base-300, text-gray-600 → text-base-content/70, hover:bg-gray-300 → hover:bg-base-200 %>
              <% end %>

              <span>
                <%= media_item.chapters_read %> / <%= media_item.total_chapters.presence || '?' %>
              </span>

              <% if user_signed_in? && current_user == media_item.user %>
                <%= button_to "+", increment_chapter_media_item_path(media_item), method: :patch,
                    class: "flex items-center justify-center h-5 w-5 rounded-full bg-base-300 text-base-content/70 hover:bg-base-200 transition" %>
              <% end %>
            </div>
          </div>

          <% progress = media_item.total_chapters.to_i > 0 ? (media_item.chapters_read.to_f / media_item.total_chapters.to_f) * 100 : 0 %>
          <div class="w-full bg-base-300 rounded-full h-1.5 mt-1">
            <%# bg-gray-200 → bg-base-300 for neutral track background %>
            <div class="bg-primary h-1.5 rounded-full" style="width: <%= progress %>%"></div>
            <%# bg-blue-600 → bg-primary for theme-colored progress fill %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
