<%
  user = forum_post.user
  viewer_id = local_assigns[:current_user]&.id
  is_current = (viewer_id.present? && user&.id == viewer_id)
%>

<div class="chat <%= is_current ? 'chat-end' : 'chat-start' %>" id="forum_post_<%= forum_post.id %>">
  <div class="chat-image avatar">
    <div class="w-10 rounded-full ring <%= is_current ? 'ring-primary' : 'ring-base-content/20' %> ring-offset-base-100 ring-offset-2">
      <% if user&.avatar&.attached? %>
        <%= image_tag url_for(user.avatar.variant(resize_to_fill: [40, 40])), class: "rounded-full" %>
      <% else %>
        <div class="w-full h-full bg-base-300 flex items-center justify-center font-bold">
          <%= user&.username&.first&.upcase || "?" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="chat-header opacity-75">
    <%= user&.username || "[Deleted User]" %>
    <time class="text-xs ml-2">
      <%= forum_post.created_at ? time_ago_in_words(forum_post.created_at) : "[Unknown Date]" %> ago
    </time>
  </div>

  <div class="chat-bubble <%= is_current ? 'chat-bubble-primary' : 'chat-bubble-secondary' %> prose max-w-none shadow-lg">
    <%= forum_post.content.to_s %>
  </div>

  <% if is_current %>
    <div class="chat-footer opacity-50 text-xs">
      Sent
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 inline ml-1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
      </svg>
    </div>
  <% end %>
</div>
