<main class="grid min-h-screen w-full place-items-center bg-base-200 px-6 lg:px-8">
  <div class="flex items-start">
    
    <p class="text-error text-5xl sm:text-7xl font-bold">404</p>
    
    <div class="border-base-300 border-l ml-6 pl-6">
      
      <div class="flex flex-col">
        <h1 class="text-base-content text-3xl sm:text-4xl font-bold tracking-tight">Profile Not Found</h1>
        <p class="text-base text-base-content/70 mt-2">Sorry, we couldn't find the profile you're looking for.</p>
      </div>

      <div class="flex items-center gap-x-4 mt-10">
        <%= link_to "Go back home", root_path, class: "btn btn-error" %>
      </div>
    </div>

  </div>
</main>
