<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="bg-base-100 rounded-lg shadow-xl overflow-hidden"> 
    <%# bg-white → bg-base-100 so it adapts to current DaisyUI theme %>

    <div class="grid grid-cols-1 md:grid-cols-3">

      <div class="md:col-span-1">
        <% if @media_item.cover_image.attached? %>
          <%= image_tag @media_item.cover_image, class: "w-full h-full object-cover" %>
        <% else %>
          <div class="w-full h-full bg-base-200 flex items-center justify-center">
            <%# bg-gray-200 → bg-base-200 for theme-aware placeholder background %>
            <span class="text-base-content/50">No Image</span>
            <%# text-gray-500 → text-base-content/50 for lighter, theme-aware text %>
          </div>
        <% end %>
      </div>

      <div class="md:col-span-2 p-6 md:p-8 flex flex-col">
        <div>
          <p class="text-base font-semibold text-primary uppercase tracking-wider">
            <%# text-indigo-600 → text-primary for theme-based primary accent %>
            <%= @media_item.category.name %>
          </p>
          <h1 class="text-4xl font-bold text-base-content mt-1">
            <%# text-gray-900 → text-base-content for readable themed text %>
            <%= @media_item.title %>
          </h1>

          <div class="flex items-center flex-wrap gap-2 mt-4">
            <span class="inline-flex items-center rounded-full bg-primary/20 px-3 py-1 text-sm font-medium text-primary">
              <%# bg-blue-100 → bg-primary/20 & text-blue-800 → text-primary for theme match %>
              <%= @media_item.status %>
            </span>
            <% if @media_item.rating.present? %>
              <span class="inline-flex items-center rounded-full bg-warning/20 px-3 py-1 text-sm font-medium text-warning">
                <%# bg-yellow-100 → bg-warning/20 & text-yellow-800 → text-warning %>
                ⭐ <%= @media_item.rating %> / 10
              </span>
            <% end %>
          </div>

          <% if @media_item.chapters_read.present? %>
            <div class="mt-6">
              <div class="flex justify-between text-sm font-medium text-base-content/70">
                <%# text-gray-600 → text-base-content/70 for subtle themed text %>
                <span>Chapters</span>
                <span>
                  <%= @media_item.chapters_read %> / <%= @media_item.total_chapters.presence || '?' %>
                </span>
              </div>
              <% progress = @media_item.total_chapters.to_i > 0 ? (@media_item.chapters_read.to_f / @media_item.total_chapters.to_f) * 100 : 0 %>
              <div class="w-full bg-base-300 rounded-full h-2.5 mt-1">
                <%# bg-gray-200 → bg-base-300 for neutral theme background %>
                <div class="bg-primary h-2.5 rounded-full" style="width: <%= progress %>%"></div>
                <%# bg-blue-600 → bg-primary for theme-colored progress bar %>
              </div>
            </div>
          <% end %>

          <p class="text-base-content/80 text-base leading-relaxed mt-6">
            <%# text-gray-700 → text-base-content/80 for slightly muted themed text %>
            <%= @media_item.description %>
          </p>
        </div>

        <div class="mt-8 pt-6 border-t border-base-300 flex items-center gap-4 flex-wrap">
          <%# border-gray-200 → border-base-300 for themed divider %>

          <%= link_to "Edit Item", edit_media_item_path(@media_item),
              class: "inline-block bg-primary text-primary-content px-4 py-2 rounded-md font-semibold hover:bg-primary-focus" %>
          <%# bg-indigo-600 → bg-primary, text-white → text-primary-content, hover:bg-indigo-700 → hover:bg-primary-focus %>

          <%= button_to "Destroy", @media_item, method: :delete, data: { turbo_confirm: 'Are you sure?' },
              class: "inline-block bg-error text-error-content px-4 py-2 rounded-md font-semibold hover:bg-error-focus" %>
          <%# bg-red-600 → bg-error, text-white → text-error-content, hover:bg-red-700 → hover:bg-error-focus %>

          <%= link_to "← Back to Collection", media_items_path,
              class: "text-primary font-medium hover:text-primary-focus ml-auto" %>
          <%# text-indigo-600 → text-primary, hover:text-indigo-800 → hover:text-primary-focus %>
        </div>
      </div>
    </div>
  </div>
</div>
