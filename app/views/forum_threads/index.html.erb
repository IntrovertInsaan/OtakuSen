<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-base-content">Forum</h1>
    <%= link_to "Start New Discussion", new_forum_thread_path, class: "btn btn-primary" %>
  </div>

  <div class="space-y-4">
    <% @forum_threads.each do |forum_thread| %>
      <div class="card bg-base-100 shadow-md hover:shadow-xl transition-shadow">
        <div class="card-body p-4 flex-row justify-between items-center">
          <div>
            <h2 class="card-title"><%= link_to forum_thread.title, forum_thread, class: "link link-hover" %></h2>
            <p class="text-sm text-base-content/70">
              Started by <%= forum_thread.user.username %> - <%= forum_thread.forum_posts.count %> replies
            </p>
          </div>
          <div class="text-right">
            <p class="text-sm font-semibold">Last Reply</p>
            <p class="text-xs text-base-content/70"><%= time_ago_in_words(forum_thread.forum_posts.last.created_at) %> ago</p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  <div class="mt-8"><%== pagy_nav_tailwind(@pagy) %></div>
</div>
