<nav class="navbar bg-base-300 text-base-content shadow-lg px-4">
  <!-- Left: Hamburger for mobile -->
  <div class="flex-none lg:hidden">
    <label for="menu-drawer" class="btn btn-square btn-ghost">
      <%= icon "bars-3", class: "h-10 w-10" %>
    </label>
  </div>

  <!-- Drawer toggle -->
  <input id="menu-drawer" type="checkbox" class="drawer-toggle hidden" />

  <!-- Logo -->
  <div class="flex-none">
    <% if user_signed_in? %>
      <%= link_to "OtakuSen", profile_path(current_user), class: "btn btn-ghost normal-case text-2xl font-bold" %>
    <% else %>
      <%= link_to "OtakuSen", root_path, class: "btn btn-ghost normal-case text-2xl font-bold" %>
    <% end %>
  </div>

  <!-- Desktop menu -->
  <div class="flex-none hidden lg:flex ml-4">
    <% if user_signed_in? %>
      <%= link_to "My Collection", media_items_path, class: "btn btn-ghost" %>
      <%= link_to "My Favorites", favorites_media_items_path, class: "btn btn-ghost" %>
      <%= link_to "Dashboard", dashboard_path, class: "btn btn-ghost" %>
    <% end %>
  </div>

  <!-- Spacer -->
  <div class="flex-1"></div>

  <!-- Right side: Search + Auth buttons -->
  <div class="flex items-center gap-3">

    <%# Theme Switcher %>
    <div class="dropdown dropdown-end">
      <div tabindex="0" role="button" class="btn btn-ghost gap-2">
        <span class="hidden sm:inline">Theme</span>
        <%= icon "chevron-down", class: "w-5 h-5" %>
      </div>
      <ul class="dropdown-content z-[1] p-2 shadow-lg bg-base-300 rounded-box w-32 menu menu-sm" data-controller="theme">
        <li><a href="#" data-action="click->theme#switch" data-theme="otakusen" class="flex items-center gap-2"><%= icon "otakusen", class: "w-4 h-4" %> Otakusen</a></li>
        <li><a href="#" data-action="click->theme#switch" data-theme="lofi" class="flex items-center gap-2"><%= icon "sun", class: "w-4 h-4" %> Light</a></li>
        <li><a href="#" data-action="click->theme#switch" data-theme="black" class="flex items-center gap-2"><%= icon "moon", class: "w-4 h-4" %> Dark</a></li>
        <li><a href="#" data-action="click->theme#switch" data-theme="valentine" class="flex items-center gap-2"><%= icon "valentine", class: "w-4 h-4" %> Love</a></li>
        <li><a href="#" data-action="click->theme#switch" data-theme="luxury" class="flex items-center gap-2"><%= icon "gold", class: "w-4 h-4" %> Gold</a></li>
        <li><a href="#" data-action="click->theme#switch" data-theme="retro" class="flex items-center gap-2"><%= icon "tv", class: "w-4 h-4" %> Arcade</a></li>
        <li><a href="#" data-action="click->theme#switch" data-theme="halloween" class="flex items-center gap-2"><%= icon "cake", class: "w-4 h-4" %>Happy</a></li>
      </ul>
    </div>

    <label class="swap swap-rotate" data-controller="theme">
      <input type="checkbox" class="theme-controller" value="black"
             data-action="change->theme#toggle"
             data-theme-toggle />
      
      <div class="swap-off fill-current w-6 h-6">
        <%= icon "sun" %>
      </div>
    
      <div class="swap-on fill-current w-6 h-6">
        <%= icon "moon" %>
      </div>
    </label>

    <%# Search %>
    <%= form_with(url: media_items_path, method: :get, class: "form-control", 
                  data: { controller: "search-form", turbo_frame: "results" }) do |form| %>
      <label class="input input-bordered flex items-center gap-2 bg-base-200 text-base-content">
        <%= icon "magnifying-glass", class: "h-5 w-5 opacity-70" %>
        <%= form.text_field :search, value: params[:search],
              placeholder: "Search...",
              class: "grow bg-transparent border-none focus:outline-none",
              data: { action: "input->search-form#search" } %>
      </label>
    <% end %>

    <%# Avatar / Auth %>
    <% if user_signed_in? %>
      <!-- Avatar dropdown (desktop & responsive) -->
      <div class="relative" data-controller="dropdown">
        <button type="button" 
                data-action="click->dropdown#toggle" 
                class="flex items-center rounded-full focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2">
          <span class="sr-only">Open user menu</span>
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar.variant(resize_to_fill: [40, 40]), class: "h-10 w-10 rounded-full shadow-md" %>
          <% else %>
            <div class="h-10 w-10 rounded-full bg-neutral text-neutral-content flex items-center justify-center shadow-md">
              <%= icon "user", class: "h-6 w-6" %>
            </div>
          <% end %>
        </button>

        <div data-dropdown-target="menu" 
             class="hidden absolute right-0 z-10 mt-2 w-64 origin-top-right rounded-xl bg-base-100 text-base-content shadow-lg ring-1 ring-base-300 overflow-hidden">
          <!-- Profile Header -->
          <div class="flex items-center gap-3 p-4 bg-base-200 border-b border-base-300">
            <% if current_user.avatar.attached? %>
              <%= image_tag current_user.avatar.variant(resize_to_fill: [48, 48]), class: "h-12 w-12 rounded-full shadow-md" %>
            <% else %>
              <div class="h-12 w-12 rounded-full bg-neutral text-neutral-content flex items-center justify-center">
                <%= icon "user", class: "h-6 w-6" %>
              </div>
            <% end %>
            <div>
              <p class="font-semibold text-base"><%= current_user.username %></p>
              <p class="text-xs text-base-content">Signed in as</p>
            </div>
          </div>

          <!-- Menu Links -->
          <ul class="menu p-2 text-base-content">
            <li>
              <%= link_to edit_user_registration_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-300" do %>
                <%= icon "cog-8-tooth", class: "h-5 w-5" %>
                <span>Edit Profile</span>
              <% end %>
            </li>
            <li>
              <%= button_to destroy_user_session_path, method: :delete, 
                    class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-error hover:text-error-content w-full text-left font-semibold" do %>
                <%= icon "arrow-right-on-rectangle", class: "h-5 w-5" %>
                <span>Log out</span>
              <% end %>
            </li>
          </ul>
        </div>
      </div>
    <% else %>
      <div class="flex gap-2">
        <%= link_to "Sign up", new_user_registration_path, class: "btn btn-primary" %>
        <%= link_to "Log in", new_user_session_path, class: "btn btn-ghost" %>
      </div>
    <% end %>
  </div>

  <!-- Drawer (mobile menu) -->
  <div class="drawer-side z-50">
    <label for="menu-drawer" class="drawer-overlay"></label>
    <div class="w-72 bg-base-200 text-base-content h-full flex flex-col">

      <!-- Header -->
      <div class="p-4 bg-base-300 border-b border-base-300">
        <%= link_to "OtakuSen", profile_path(1), class: "text-lg font-bold" %>
      </div>

      <!-- User info -->
      <% if user_signed_in? %>
        <div class="p-4 flex items-center gap-3 border-b border-base-300 bg-base-100">
          <% if current_user.avatar.attached? %>
            <%= image_tag current_user.avatar.variant(resize_to_fill: [48, 48]), class: "h-12 w-12 rounded-full shadow-md" %>
          <% else %>
            <div class="h-12 w-12 rounded-full bg-neutral text-neutral-content flex items-center justify-center"></div>
          <% end %>
          <div>
            <p class="font-semibold text-base"><%= current_user.username || "User" %></p>
            <%= link_to "View Profile", profile_path(current_user), class: "text-xs text-primary hover:underline" %>
          </div>
        </div>
      <% end %>

      <!-- Menu items -->
      <ul class="menu flex-1 p-4 text-base-content space-y-2">
        <% if user_signed_in? %>
          <li>
            <%= link_to media_items_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-300" do %>
              <%= icon "rectangle-stack", class: "h-8 w-8" %>
              <span>My Collection</span>
            <% end %>
          </li>
          <li>
            <%= link_to dashboard_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-300" do %>
              <%= icon "chart-bar", class: "h-8 w-8" %>
              <span>Dashboard</span>
            <% end %>
          </li>
          <li>
            <%= link_to edit_user_registration_path, class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-base-300" do %>
              <%= icon "cog-8-tooth", class: "h-8 w-8" %>
              <span>Edit Profile</span>
            <% end %>
          </li>
          <li>
            <%= button_to destroy_user_session_path, method: :delete, 
                  class: "flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-error hover:text-error-content w-full text-left font-semibold" do %>
              <%= icon "arrow-right-on-rectangle", class: "h-8 w-8" %>
              <span>Log out</span>
            <% end %>
          </li>
        <% else %>
          <li><%= link_to "Sign up", new_user_registration_path, class: "hover:bg-base-300 rounded-lg px-3 py-2" %></li>
          <li><%= link_to "Log in", new_user_session_path, class: "hover:bg-base-300 rounded-lg px-3 py-2" %></li>
        <% end %>
      </ul>

      <!-- Footer -->
      <div class="p-4 border-t border-base-300 text-xs text-base-content/70 text-center">
        &copy; <%= Time.current.year %> OtakuSen
      </div>
    </div>
  </div>
</nav>
