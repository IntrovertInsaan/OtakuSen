<div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8 border-t border-base-300 pt-4">

  <div class="btn-group">
    <%= link_to "All", @path.call(@current_params.except(:category_id)), class: "btn btn-sm #{@current_params[:category_id].blank? ? 'btn-primary' : 'btn-ghost'}" %>
    <% @categories.each do |category| %>
      <% is_active = @current_params[:category_id].to_s == category.id.to_s %>
      <%= link_to category.name, @path.call(@current_params.merge(category_id: category.id)), class: "btn btn-sm #{is_active ? 'btn-primary' : 'btn-ghost'}" %>
    <% end %>
  </div>
  
  <div class="flex items-center gap-2">
    <div class="dropdown dropdown-end">
      <div tabindex="0" role="button" class="btn btn-sm btn-ghost">
        <%= helpers.icon "arrows-up-down", class: "h-5 w-5" %>
        Sort
      </div>
      <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-200 rounded-box w-52">
        <li><%= link_to "Default", @path.call(@current_params.except(:sort)) %></li>
        <li><%= link_to "Highest Rated", @path.call(@current_params.merge(sort: 'highest_rated')) %></li>
        <li><%= link_to "Recently Updated", @path.call(@current_params.merge(sort: 'recently_updated')) %></li>
        <li><%= link_to "Title (A-Z)", @path.call(@current_params.merge(sort: 'title_asc')) %></li>
        <li><%= link_to "Title (Z-A)", @path.call(@current_params.merge(sort: 'title_desc')) %></li>
      </ul>
    </div>
  
    <div class="dropdown dropdown-end">
      <div tabindex="0" role="button" class="btn btn-sm btn-ghost">
        <span class="mr-1"><%= @current_params[:tag].presence || "Filter by Tag" %></span>
        <svg width="12px" height="12px" class="h-2 w-2 fill-current" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 2048 2048"><path d="M1799 349l242 241-1017 1017L7 590l242-241 775 775 775-775z"></path></svg>
      </div>
      <ul tabindex="0" class="dropdown-content z-[1] menu p-2 shadow bg-base-200 rounded-box w-52 max-h-60 overflow-y-auto">
        <li><%= link_to "All Tags", @path.call(@current_params.except(:tag)) %></li>
        <% @tags.each do |tag| %>
          <li>
            <%= link_to tag.name, @path.call(@current_params.merge(tag: tag.name)) %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>
