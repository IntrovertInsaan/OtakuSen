<% user = forum_post.user %>
<% is_current = (user == local_assigns[:current_user]) %>

<% if is_current %>
  <div class="chat chat-end">
    <div class="chat-image avatar">
      <div class="w-10 rounded-full">
        <% if user&.avatar&.attached? %>
          <%= image_tag user.avatar.variant(resize_to_fill: [40, 40]) %>
        <% else %>
          <div class="w-10 h-10 bg-gray-600 flex items-center justify-center text-gray-200 font-bold">
            <%= user&.username&.first&.upcase || "?" %>
          </div>
        <% end %>
      </div>
    </div>
    <div class="chat-header">
      <%= user&.username || "[Deleted User]" %>
      <time class="text-xs opacity-50">
        <%= forum_post.created_at ? time_ago_in_words(forum_post.created_at) : "[Unknown Date]" %> ago
      </time>
    </div>
    <div class="chat-bubble chat-bubble-primary prose max-w-none text-primary-content">
      <%= forum_post.content.to_s %>
    </div>
  </div>
<% else %>
  <div class="chat chat-start">
    <div class="chat-image avatar">
      <div class="w-10 rounded-full">
        <% if user&.avatar&.attached? %>
          <%= image_tag user.avatar.variant(resize_to_fill: [40, 40]) %>
        <% else %>
          <div class="w-10 h-10 bg-gray-600 flex items-center justify-center text-gray-200 font-bold">
            <%= user&.username&.first&.upcase || "?" %>
          </div>
        <% end %>
      </div>
    </div>
    <div class="chat-header">
      <%= user&.username || "[Deleted User]" %>
      <time class="text-xs opacity-50">
        <%= forum_post.created_at ? time_ago_in_words(forum_post.created_at) : "[Unknown Date]" %> ago
      </time>
    </div>
    <div class="chat-bubble prose max-w-none">
      <%= forum_post.content.to_s %>
    </div>
  </div>
<% end %>
