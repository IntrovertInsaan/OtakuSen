<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="rounded-lg bg-base-100 shadow-xl p-6 md:p-8">
    <h2 class="text-base-content text-3xl font-bold text-center tracking-tight mb-6">Forgot your password?</h2>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "block text-base-content text-sm font-medium leading-6" %>
        <div class="mt-2">
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
        </div>
      </div>

      <div class="mt-6">
        <%= f.submit "Send me reset instructions", class: "btn btn-primary w-full" %>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
