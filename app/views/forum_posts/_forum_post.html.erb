<%
  user = forum_post.user
  viewer_id = local_assigns[:current_user]&.id
  is_current = (viewer_id.present? && user&.id == viewer_id)
%>

<div class="chat <%= is_current ? 'chat-end' : 'chat-start' %>" id="forum_post_<%= forum_post.id %>">
  <div class="chat-image avatar">
    <div class="w-8 rounded-full <%= is_current ? 'bg-primary/10' : 'bg-base-300' %>">
      <% if user&.avatar&.attached? %>
        <%= image_tag url_for(user.avatar.variant(resize_to_fill: [32, 32])), class: "rounded-full" %>
      <% else %>
        <div class="w-full h-full flex items-center justify-center text-sm font-medium">
          <%= user&.username&.first&.upcase || "?" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="chat-header text-xs opacity-75">
    <%= user&.username || "[Deleted User]" %>
    <time class="ml-1">• <%= forum_post.created_at ? time_ago_in_words(forum_post.created_at) : "[Unknown Date]" %> ago</time>
  </div>

  <div class="chat-bubble <%= is_current ? 'chat-bubble-primary' : '' %> prose max-w-none">
    <%= forum_post.content.to_s %>
  </div>

  <% if is_current %>
    <div class="chat-footer opacity-50 text-[10px]">
      Delivered
    </div>
  <% end %>
</div>
