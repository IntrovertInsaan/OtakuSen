<%= form_with(model: media_item, class: "space-y-6") do |form| %>
  <% if media_item.errors.any? %>
    <div class="alert alert-error shadow-lg">
      <div>
        <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
        <div>
          <h3 class="font-bold"><%= pluralize(media_item.errors.count, "error") %> prohibited this from being saved:</h3>
          <ul class="mt-2 list-disc list-inside">
            <% media_item.errors.full_messages.each do |message| %>
              <li class="text-sm"><%= message %></li>
            <% end %>
          </ul>
        </div>
      </div>
    </div>
  <% end %>

  <div class="form-control w-full">
    <%= form.label :title, class: "label" %>
    <%= form.text_field :title, class: "input input-bordered w-full" %>
  </div>

  <div class="form-control w-full">
    <%= form.label :category_id, class: "label" %>
    <%= form.collection_select :category_id, @categories, :id, :name, { prompt: "Select a Category" }, { class: "select select-bordered w-full" } %>
  </div>

  <div class="form-control w-full">
    <%= form.label :cover_image, class: "label" %>
    <%= form.file_field :cover_image, class: "file-input file-input-bordered w-full" %>
  </div>

  <div class="form-control w-full">
    <%= form.label :description, class: "label" %>
    <%= form.text_area :description, rows: 4, class: "textarea textarea-bordered w-full" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div class="form-control w-full">
      <%= form.label :status, class: "label" %>
      <%= form.select :status, ["Planning", "In Progress", "Completed", "On Hold", "Dropped"], { prompt: "Select a Status" }, { class: "select select-bordered w-full" } %>
    </div>
    <div class="form-control w-full">
      <%= form.label :rating, "Overall Rating (1-10)", class: "label" %>
      <%= form.number_field :rating, in: 1..10, class: "input input-bordered w-full" %>
    </div>
  </div>
  
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
    <div class="form-control w-full">
      <%= form.label :story_rating, "Story (1-10)", class: "label" %>
      <%= form.number_field :story_rating, in: 1..10, class: "input input-bordered w-full" %>
    </div>
    <div class="form-control w-full">
      <%= form.label :art_rating, "Art (1-10)", class: "label" %>
      <%= form.number_field :art_rating, in: 1..10, class: "input input-bordered w-full" %>
    </div>
    <div class="form-control w-full">
      <%= form.label :characters_rating, "Characters (1-10)", class: "label" %>
      <%= form.number_field :characters_rating, in: 1..10, class: "input input-bordered w-full" %>
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
    <div class="form-control w-full">
      <%= form.label :chapters_read, class: "label" %>
      <%= form.number_field :chapters_read, class: "input input-bordered w-full" %>
    </div>
    <div class="form-control w-full">
      <%= form.label :total_chapters, class: "label" %>
      <%= form.number_field :total_chapters, class: "input input-bordered w-full" %>
    </div>
  </div>

  <div class="form-control w-full">
    <%= form.label :tag_list, "Tags (comma separated)", class: "label" %>
    <%= form.text_field :tag_list, class: "input input-bordered w-full" %>
  </div>

  <div class="card-actions justify-end">
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>
