<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="rounded-lg bg-base-100 p-6 md:p-8 shadow-xl">
    <h2 class="text-base-content text-3xl font-bold text-center tracking-tight mb-6">Log in</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="space-y-6">
        <div>
          <%= f.label :email, class: "block text-base-content text-sm font-medium leading-6" %>
          <div class="mt-2">
            <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "input input-bordered w-full" %>
          </div>
        </div>

        <div>
          <%= f.label :password, class: "block text-base-content text-sm font-medium leading-6" %>
          <div class="mt-2">
            <%= f.password_field :password, autocomplete: "current-password", class: "input input-bordered w-full" %>
          </div>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="form-control">
            <label class="label cursor-pointer justify-start gap-4">
              <%= f.check_box :remember_me, class: "checkbox checkbox-primary" %>
              <span class="label-text"><%= f.label :remember_me %></span> 
            </label>
          </div>
        <% end %>

        <div>
          <%= f.submit "Log in", class: "btn btn-primary w-full" %>
        </div>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
