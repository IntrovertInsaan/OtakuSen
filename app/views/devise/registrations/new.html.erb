<div class="max-w-md mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="rounded-lg bg-base-100 shadow-xl p-6 md:p-8">
    <h2 class="text-base-content text-3xl font-bold text-center tracking-tight mb-6">Sign up</h2>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="space-y-6">
        <div>
          <%= f.label :username, class: "block text-base-content text-sm font-medium leading-6" %>
          <div class="mt-2">
            <%= f.text_field :username, autofocus: true, autocomplete: "username", class: "input input-bordered w-full" %>
          </div>
        </div>

        <div>
          <%= f.label :email, class: "block text-base-content text-sm font-medium leading-6" %>
          <div class="mt-2">
            <%= f.email_field :email, autocomplete: "email", class: "input input-bordered w-full" %>
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between">
            <%= f.label :password, class: "block text-base-content text-sm font-medium leading-6" %>
            <% if @minimum_password_length %>
              <em class="text-base-content/60 text-xs">(<%= @minimum_password_length %> characters minimum)</em>
            <% end %>
          </div>
          <div class="mt-2">
            <%= f.password_field :password, autocomplete: "new-password", class: "input input-bordered w-full" %>
          </div>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "block text-base-content text-sm font-medium leading-6" %>
          <div class="mt-2">
            <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "input input-bordered w-full" %>
          </div>
        </div>

        <div>
          <%= f.submit "Sign up", class: "btn btn-primary w-full" %>
        </div>
      </div>
    <% end %>

    <div class="mt-6 text-center">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
