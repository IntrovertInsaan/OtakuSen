<div id="<%= dom_id(media_item) %>" class="flex rounded-lg bg-base-100 shadow-lg overflow-hidden hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
  
  <div class="w-1/3 flex-shrink-0">
    <% if media_item.cover_image.attached? %>
      <%= image_tag media_item.cover_image.variant(resize_to_fill: [400, 600]), class: "w-full h-full object-cover" %>
    <% else %>
      <div class="flex justify-center items-center w-full h-full p-2 bg-base-200 text-center">
        <span class="text-base-content/50 text-xs ml-2">No Image</span>
      </div>
    <% end %>
  </div>

  <div class="flex flex-col justify-between w-2/3 p-4">

    <div>
      <p class="uppercase text-primary text-sm font-semibold tracking-wider">
        <%= media_item.category.name %>
      </p>

      <h2 class="text-xl font-bold text-base-content mt-1 truncate" title="<%= media_item.title %>">
        <%= link_to media_item.title, media_item, data: { turbo_frame: "_top" }, class: "hover:text-primary" %>
      </h2>
      
      <div class="flex items-center flex-wrap gap-2 mt-2">
        <span class="inline-flex items-center rounded-full px-2 py-0.5 bg-primary/20 text-primary text-xs font-medium">
          <%= media_item.status %>
        </span>
        <% if media_item.rating.present? %>
          <span class="inline-flex items-center rounded-full px-2 py-0.5 bg-warning/20 text-warning text-xs font-medium">
            ⭐ <%= media_item.rating %> / 10
          </span>
        <% end %>
      </div>
      
      <p class="text-base-content/70 text-sm leading-relaxed mt-3">
        <%= truncate(media_item.description, length: 80) %>
      </p>

      <% if media_item.chapters_read.present? %>
        <div class="mt-4">
          <div class="flex justify-between items-center text-base-content/60 text-xs font-medium">
            <span>Chapters</span>
            <div class="flex items-center gap-2">
              <% if user_signed_in? && current_user == media_item.user %>
                <%= button_to "-", decrement_chapter_media_item_path(media_item), method: :patch,
                    class: "flex justify-center items-center h-5 w-5 rounded-full bg-base-300 text-base-content/70 hover:bg-base-200 transition" %>
              <% end %>

              <span>
                <%= media_item.chapters_read %> / <%= media_item.total_chapters.presence || '?' %>
              </span>

              <% if user_signed_in? && current_user == media_item.user %>
                <%= button_to "+", increment_chapter_media_item_path(media_item), method: :patch,
                    class: "flex justify-center items-center h-5 w-5 rounded-full bg-base-300 text-base-content/70 hover:bg-base-200 transition" %>
              <% end %>
            </div>
          </div>

          <% progress = media_item.total_chapters.to_i > 0 ? (media_item.chapters_read.to_f / media_item.total_chapters.to_f) * 100 : 0 %>
          <div class="w-full rounded-full bg-base-300 h-1.5 mt-1">
            <div class="rounded-full bg-primary h-1.5" style="width: <%= progress %>%"></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
