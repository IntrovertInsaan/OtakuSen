<div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="lg:hidden p-4">
    <%= render "layouts/navbar/search_bar" %>
  </div>
  <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center gap-4 mb-8">
    <h1 class="text-3xl font-bold text-base-content tracking-tight"><%= @page_title || "My Collection" %></h1>
    <div class="flex items-center gap-4">
      <% if user_signed_in? %>
        <%= link_to "Add New Item", new_media_item_path, class: "btn btn-primary" %>
      <% end %>
      <div class="btn-group">
        <%= link_to icon("squares", class: "h-5 w-5"),
              url_for(params.to_unsafe_h.merge(view: 'grid')), 
              class: "btn btn-sm #{params[:view] != 'list' ? 'btn-primary' : 'btn-ghost'}" %>
        <%= link_to icon("bars-3", class: "h-5 w-5"), 
              url_for(params.to_unsafe_h.merge(view: 'list')), 
              class: "btn btn-sm #{params[:view] == 'list' ? 'btn-primary' : 'btn-ghost'}" %>
      </div>
    </div>
  </div>

  <%= render(FilterBarComponent.new(
      path: ->(p={}) { url_for(p) },
      categories: @categories,
      tags: @tags,
      current_params: params.to_unsafe_h.slice(:search, :tag, :view, :category_id, :sort)
  )) %>

  <%= turbo_frame_tag "results" do %>
    <% if @media_items.any? %>
      <% is_list_view = params[:view] == 'list' %>
      <% container_class = is_list_view ? 'flex flex-col gap-3' : 'grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8' %>

      <div class="<%= container_class %>">
        <% if is_list_view %>
          <%= render partial: 'media_items/list_item', collection: @media_items, as: :media_item %>
        <% else %>
          <%= render partial: 'media_items/grid_item', collection: @media_items, as: :media_item %>
        <% end %>
      </div>

      <div class="mt-12">
        <%== pagy_nav_tailwind(@pagy) %>
      </div>

    <% else %>
      <div class="rounded-lg px-6 py-16 bg-base-100 text-center shadow-md">
        <h3 class="text-xl font-semibold text-base-content">No results found.</h3>
        <p class="text-base-content/70 mt-2">Try adjusting your search or filter.</p>
      </div>
    <% end %>
  <% end %>
</div>
