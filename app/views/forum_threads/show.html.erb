<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h1 class="text-3xl font-bold text-base-content mb-2"><%= @thread.title %></h1>
  <p class="text-base-content/70 mb-8">A discussion started by <%= @thread.user.username %></p>

  <%= turbo_stream_from "forum_thread_#{@thread.id}" %>

  <!-- List of posts -->
  <div id="<%= dom_id(@thread) %>" class="space-y-6">
    <%# This now renders your new partial for each post %>
    <%= render partial: "forum_posts/forum_post", collection: @posts, as: :forum_post %>
  </div>

  <!-- Reply Form -->
  <div class="mt-12 text-right">
    <button class="btn btn-primary" onclick="reply_modal.showModal()">Post a Reply</button>
  </div>
  
  <dialog id="reply_modal" class="modal">
    <div class="modal-box w-11/12 max-w-4xl">
      <h3 class="font-bold text-lg mb-4">Your Reply</h3>
      
      <%= form_with(model: [@thread, @new_post]) do |f| %>
        <div class="form-control">
          <%= f.rich_text_area :content, class: "textarea textarea-bordered w-full h-48" %>
        </div>
        <div class="modal-action">
          <form method="dialog">
            <button class="btn btn-ghost">Cancel</button>
          </form>
          <%= f.submit "Post Reply", class: "btn btn-primary" %>
        </div>
      <% end %>
      
    </div>
    <form method="dialog" class="modal-backdrop"><button>close</button></form>
  </dialog>
</div>
