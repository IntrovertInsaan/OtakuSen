<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h1 class="text-3xl font-bold tracking-tight text-base-content mb-8">Admin Dashboard</h1>

  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

    <div class="stats shadow">
      <div class="stat">
        <div class="stat-figure text-primary"><%= icon "users", class: "w-8 h-8" %></div>
        <div class="stat-title">Total Users</div>
        <div class="stat-value"><%= @total_users %></div>
      </div>
    </div>

    <div class="stats shadow">
      <div class="stat">
        <div class="stat-figure text-secondary"><%= icon "rectangle-stack", class: "w-8 h-8" %></div>
        <div class="stat-title">Total Media Items</div>
        <div class="stat-value"><%= @total_media_items %></div>
      </div>
    </div>

    <div class="stats shadow">
      <div class="stat">
        <div class="stat-figure text-accent"><%= icon "pencil-square", class: "w-8 h-8" %></div>
        <div class="stat-title">Total Notes</div>
        <div class="stat-value"><%= @total_notes %></div>
      </div>
    </div>

  </div>
</div>
