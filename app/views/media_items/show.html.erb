<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="card lg:card-side bg-base-100 shadow-xl">
    
    <figure class="lg:w-1/3">
      <% if @media_item.cover_image.attached? %>
        <%= image_tag @media_item.cover_image.variant(resize_to_fill: [800, 1200]), class: "w-full h-full object-cover" %>
      <% else %>
        <div class="w-full h-full bg-base-200 flex items-center justify-center text-base-content/50">
          <%= icon "photo", class: "w-24 h-24" %>
        </div>
      <% end %>
    </figure>

    <div class="card-body lg:w-2/3 flex flex-col">
      
      <div class="flex-grow">
        <p class="text-base font-semibold text-primary uppercase tracking-wider"><%= @media_item.category.name %></p>
        <h1 class="card-title text-4xl font-bold mt-1"><%= @media_item.title %></h1>
        
        <div class="flex justify-between items-center mt-4">
          <div class="flex items-center flex-wrap gap-2">
            <div class="badge badge-lg badge-outline"><%= @media_item.status %></div>
            <% if @media_item.rating.present? %>
              <div class="badge badge-lg badge-outline">⭐ Overall: <%= @media_item.rating %> / 10</div>
            <% end %>
          </div>
          <% if user_signed_in? && current_user == @media_item.user %>
            <%= turbo_frame_tag dom_id(@media_item, :notes_section) do %>
              <%= render "media_items/notes_section", media_item: @media_item %>
            <% end %>
          <% end %>
        </div>

        <div class="mt-6 p-4 bg-base-200 rounded-box space-y-3">
          <% if @media_item.story_rating.present? || @media_item.art_rating.present? || @media_item.characters_rating.present? %>
            <h3 class="font-bold text-lg">Detailed Ratings</h3>
            <% if @media_item.story_rating.present? %>
              <div class="flex items-center gap-4"><span class="font-semibold w-24">Story</span><div class="rating rating-sm"><% 10.times do |i| %><input type="radio" name="r1" class="mask mask-star-2 bg-warning" disabled <%= 'checked' if (i + 1) == @media_item.story_rating %> /><% end %></div></div>
            <% end %>
            <% if @media_item.art_rating.present? %>
              <div class="flex items-center gap-4"><span class="font-semibold w-24">Art</span><div class="rating rating-sm"><% 10.times do |i| %><input type="radio" name="r2" class="mask mask-star-2 bg-warning" disabled <%= 'checked' if (i + 1) == @media_item.art_rating %> /><% end %></div></div>
            <% end %>
            <% if @media_item.characters_rating.present? %>
              <div class="flex items-center gap-4"><span class="font-semibold w-24">Characters</span><div class="rating rating-sm"><% 10.times do |i| %><input type="radio" name="r3" class="mask mask-star-2 bg-warning" disabled <%= 'checked' if (i + 1) == @media_item.characters_rating %> /><% end %></div></div>
            <% end %>
          <% end %>
        </div>

        <% if @media_item.chapters_read.present? %>
          <div class="mt-6">
            <div class="flex justify-between text-base-content/70 text-sm font-medium"><span>Chapters</span><span><%= @media_item.chapters_read %> / <%= @media_item.total_chapters.presence || '?' %></span></div>
            <progress class="progress progress-primary w-full mt-1" value="<%= (@media_item.total_chapters.to_i > 0 ? (@media_item.chapters_read.to_f / @media_item.total_chapters.to_f) * 100 : 0) %>" max="100"></progress>
          </div>
        <% end %>

        <p class="text-base-content/80 leading-relaxed mt-6"><%= @media_item.description %></p>
      </div>
      
      <div class="card-actions justify-start items-center gap-4 pt-6 border-t border-base-300">
        <% if user_signed_in? && current_user == @media_item.user %>
          <%= link_to "Edit Item", edit_media_item_path(@media_item), class: "btn btn-secondary" %>
          <%= button_to "Delete", @media_item, method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: "btn btn-error" %>
        <% end %>
        <%= link_to "← Back to Collection", media_items_path, class: "link link-hover ml-auto" %>
      </div>
    </div>
  </div>
</div>

<dialog id="notes_modal" class="modal">
  <div class="modal-box w-11/12 max-w-4xl">
    <%= turbo_frame_tag "notes_content", src: media_item_notes_path(@media_item) %>
  </div>
  <form method="dialog" class="modal-backdrop"><button>close</button></form>
</dialog>
