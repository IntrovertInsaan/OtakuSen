<div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">My Collection</h1>
    <%= link_to "Add New Item", new_media_item_path, class: "rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
  </div>

  <% if notice.present? %>
    <div class="bg-green-100 border-l-4 border-green-500 text-green-700 p-4 mb-6 rounded-md" role="alert">
      <p class="font-bold">Success</p>
      <p><%= notice %></p>
    </div>
  <% end %>

  <% if @media_items.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      
      <% @media_items.each do |media_item| %>
        <div class="bg-white rounded-lg shadow-lg overflow-hidden flex flex-col hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
          
          <div class="p-6">
            <p class="text-sm font-semibold text-indigo-600 uppercase tracking-wider"><%= media_item.category.name %></p>
            <h2 class="text-2xl font-bold text-gray-800 mt-1 truncate" title="<%= media_item.title %>">
              <%= link_to media_item.title, media_item, class: "hover:text-indigo-700" %>
            </h2>
          </div>

          <div class="px-6 pb-6 space-y-4 flex-grow">
            <div class="flex items-center space-x-4">
              <span class="inline-flex items-center rounded-full bg-blue-100 px-3 py-1 text-xs font-medium text-blue-800">
                <%= media_item.status %>
              </span>
              <% if media_item.rating.present? %>
                <span class="inline-flex items-center rounded-full bg-yellow-100 px-3 py-1 text-xs font-medium text-yellow-800">
                  ⭐ <%= media_item.rating %> / 10
                </span>
              <% end %>
            </div>
            
            <p class="text-gray-600 text-sm leading-relaxed">
              <%= truncate(media_item.description, length: 100) %>
            </p>
          </div>

          <div class="bg-gray-50 p-4 mt-auto">
            <div class="flex justify-end space-x-3">
              <%= link_to "Edit", edit_media_item_path(media_item), class: "text-sm font-medium text-indigo-600 hover:text-indigo-900" %>
              <%= button_to "Destroy", media_item, method: :delete, data: { turbo_confirm: 'Are you sure?' }, class: "text-sm font-medium text-red-600 hover:text-red-900" %>
            </div>
          </div>
          
        </div>
      <% end %>
      
    </div>
  <% else %>
    <div class="text-center py-16 px-6 bg-white rounded-lg shadow-md">
      
      <h3 class="text-xl font-semibold text-gray-800">Your collection is empty!</h3>
      <p class="text-gray-500 mt-2">Click the "Add New Item" button to start organizing your media.</p>
    </div>
  <% end %>
</div>
