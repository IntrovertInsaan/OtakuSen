<div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold text-base-content tracking-tight">
      My Collection
    </h1>
    <% if user_signed_in? %>
      <%= link_to "Add New Item", new_media_item_path,
          class: "rounded-md px-4 py-2 bg-primary text-primary-content text-sm font-semibold hover:bg-primary-focus shadow-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary" %>
    <% end %>
  </div>

  <div class="flex items-center flex-wrap gap-2 mb-8">
    <span class="text-sm font-medium text-base-content/70 mr-2">
      Filter by:
    </span>

    <%= link_to "All", media_items_path,
        class: "rounded-full px-3 py-1 text-sm font-semibold #{params[:category_id].blank? ? 'bg-primary text-primary-content' : 'bg-base-300 text-base-content hover:bg-base-200'}"%>

    <% @categories.each do |category| %>
      <% is_active = params[:category_id].to_s == category.id.to_s %>
      <%= link_to category.name, media_items_path(category_id: category.id),
          class: "rounded-full px-3 py-1 text-sm font-semibold #{is_active ? 'bg-primary text-primary-content' : 'bg-base-300 text-base-content hover:bg-base-200'}" %>
    <% end %>
  </div>

  <% if notice.present? %>
    <div class="rounded-md p-4 mb-6 bg-success/20 border-l-4 border-success text-success" role="alert">
      <p class="font-bold">Success</p>
      <p><%= notice %></p>
    </div>
  <% end %>

  <%= turbo_frame_tag "results" do %>
    <% if @media_items.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <%= render @media_items %>
      </div>

      <div class="mt-12">
        <%= pagy_nav_tailwind(@pagy) %>
      </div>

    <% else %>
      <div class="rounded-lg px-6 py-16 bg-base-100 text-center shadow-md">
        <h3 class="text-xl font-semibold text-base-content">
          No results found.
        </h3>
        <p class="text-base-content/70 mt-2">
          Try adjusting your search or filter.
        </p>
      </div>
    <% end %>
  <% end %>
</div>
