<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h1 class="text-3xl font-bold text-base-content mb-2"><%= @thread.title %></h1>
  <p class="text-base-content/70 mb-8">A discussion started by <%= @thread.user.username %></p>

  <!-- List of posts -->
  <div class="space-y-6">
    <% @posts.each do |post| %>
      <%# This logic aligns the current user's posts to the right %>
      <% if post.user == current_user %>
        <div class="chat chat-end">
          <div class="chat-image avatar">
            <div class="w-10 rounded-full">
              <%= image_tag post.user.avatar.variant(resize_to_fill: [40, 40]) if post.user.avatar.attached? %>
            </div>
          </div>
          <div class="chat-header">
            <%= post.user.username %>
            <time class="text-xs opacity-50"><%= time_ago_in_words(post.created_at) %> ago</time>
          </div>
          <div class="chat-bubble chat-bubble-primary prose max-w-none text-primary-content"><%= post.content %></div>
        </div>
      <% else %>
        <div class="chat chat-start">
          <div class="chat-image avatar">
            <div class="w-10 rounded-full">
              <%= image_tag post.user.avatar.variant(resize_to_fill: [40, 40]) if post.user.avatar.attached? %>
            </div>
          </div>
          <div class="chat-header">
            <%= post.user.username %>
            <time class="text-xs opacity-50"><%= time_ago_in_words(post.created_at) %> ago</time>
          </div>
          <div class="chat-bubble prose max-w-none"><%= post.content %></div>
        </div>
      <% end %>
    <% end %>
  </div>

  <!-- Reply Form -->
  <div tabindex="0" class="collapse collapse-arrow border border-base-300 bg-base-100 rounded-box mt-12">
    <div class="collapse-title text-xl font-medium">Post a Reply</div>
    <div class="collapse-content">
      <%= form_with(model: [@thread, @new_post]) do |f| %>
        <div class="form-control">
          <%= f.rich_text_area :content, class: "textarea textarea-bordered w-full h-48" %>
        </div>
        <div class="card-actions justify-end mt-4">
          <%= f.submit "Post Reply", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
