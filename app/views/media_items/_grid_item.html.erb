<div id="<%= dom_id(media_item) %>" 
     class="flex rounded-lg bg-base-100 shadow-lg overflow-hidden hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
  
  <div class="w-1/3 flex-shrink-0">
    <% if media_item.cover_image.attached? %>
      <%= image_tag media_item.cover_image.variant(resize_to_fill: [400, 600]), 
                    class: "w-full h-full object-cover" %>
    <% else %>
      <div class="flex justify-center items-center w-full h-full p-2 bg-base-200 text-center">
        <span class="text-base-content/50 text-xs ml-2">No Image</span>
      </div>
    <% end %>
  </div>

  <div class="flex flex-col justify-between w-2/3 p-4">

    <div>
      <p class="uppercase text-primary text-sm font-semibold tracking-wider"><%= media_item.category.name %></p>
      <h2 class="text-xl font-bold text-base-content mt-1 truncate" 
          title="<%= media_item.title %>">
        <%= link_to media_item.title, media_item, 
                    data: { turbo_frame: "_top" }, 
                    class: "hover:text-primary" %></h2>

      <% if user_signed_in? %>
        <% is_favorited = current_user.favorited_items.include?(media_item) %>
        <%= button_to is_favorited ? unfavorite_media_item_path(media_item) : favorite_media_item_path(media_item), 
                      method: :patch, 
                      class: "btn btn-ghost btn-circle" do %>
          <%= icon "valentine", class: "h-6 w-6 #{is_favorited ? 'text-red-500' : 'text-base-content/30'}" %>
        <% end %>
      <% end %>

      <div class="flex items-center flex-wrap gap-2 mt-2">
        <div class="badge badge-outline"><%= media_item.status %></div>
        <% if media_item.rating.present? %>
          <div class="badge badge-outline">⭐ <%= media_item.rating %> / 10</div>
        <% end %>
      </div>

      <% if media_item.tags.any? %>
        <div class="mt-3 flex flex-wrap gap-1">
          <% media_item.tags.each do |tag| %>
            <%= link_to media_items_path(params.permit(:category_id, :search).merge(tag: tag.name)) do %>
              <div class="badge badge-accent badge-outline hover:badge-primary transition-colors"><%= tag.name %></div>
            <% end %>
          <% end %>
        </div>
      <% end %>
      
      <p class="text-base-content/70 text-sm leading-relaxed mt-3">
        <%= truncate(media_item.description, length: 80) %>
      </p>

      <% if media_item.chapters_read.present? %>
        <div class="mt-4">
          <div class="flex justify-between items-center text-base-content/60 text-xs font-medium">
            <span>Chapters</span>
            <div class="flex items-center gap-2">
              <% if user_signed_in? && current_user == media_item.user %>
                <%= button_to "-", decrement_chapter_media_item_path(media_item), method: :patch, disabled: media_item.chapters_read <= 0,
                    class: "btn btn-xs btn-circle bg-base-300 text-base-content hover:bg-base-200 disabled:opacity-50 disabled:cursor-not-allowed" %>
              <% end %>

              <span>
                <%= media_item.chapters_read %> / <%= media_item.total_chapters.presence || '?' %>
              </span>

              <% if user_signed_in? && current_user == media_item.user %>
                <%= button_to "+", increment_chapter_media_item_path(media_item), method: :patch, disabled: media_item.total_chapters.present? && media_item.chapters_read >= media_item.total_chapters,
                    class: "btn btn-xs btn-circle bg-base-300 text-base-content hover:bg-base-200 disabled:opacity-50 disabled:cursor-not-allowed" %>
              <% end %>
            </div>
          </div>

          <% progress = media_item.total_chapters.to_i > 0 ? (media_item.chapters_read.to_f / media_item.total_chapters.to_f) * 100 : 0 %>
          <!-- Changed to DaisyUI progress bar -->
          <progress class="progress progress-primary w-full mt-1" value="<%= progress %>" max="100"></progress>
        </div>
      <% end %>
    </div>
  </div>
</div>
