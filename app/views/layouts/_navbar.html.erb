<nav class="bg-gray-900 shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      
      <div class="flex items-center">
        <%= link_to "OtakuSen", root_path, class: "text-white text-2xl font-bold tracking-tight" %>
        <div class="hidden md:block">
          <div class="ml-10 flex items-baseline space-x-4">
            <%= link_to "My Collection", media_items_path, class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
            <%= link_to "Dashboard", dashboard_path, class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
          </div>
        </div>
      </div>

      <%# Search Bar Feature %>
      <div class="flex-1 flex justify-center px-2 lg:ml-6 lg:justify-end">
        <%# We attach our new Stimulus controller to the form itself %>
        <%= form_with(url: media_items_path, method: :get, 
                      class: "max-w-lg w-full lg:max-w-xs",
                      data: { 
                        controller: "search-form", 
                        turbo_frame: "results" 
                      }) do |form| %>

          <label for="search" class="sr-only">Search</label>
          <div class="relative text-gray-400 focus-within:text-gray-600">
            <div class="pointer-events-none absolute inset-y-0 left-0 pl-3 flex items-center">

            </div>

            <%# We add a data-action to trigger the controller's search method on input %>
            <%= form.text_field :search, 
                  value: params[:search],
                  class: "block w-full bg-gray-700 ...", 
                  placeholder: "Search live...",
                  data: { action: "input->search-form#search" } %>
          </div>
        <% end %>
      </div>
      
      <div class="hidden md:block">
        <div class="ml-4 flex items-center md:ml-6">
          <%= link_to "Add New Item", new_media_item_path, class: "bg-indigo-600 text-white px-3 py-2 rounded-md text-sm font-semibold hover:bg-indigo-500" %>
        </div>
      </div>

    </div>
  </div>
</nav>
