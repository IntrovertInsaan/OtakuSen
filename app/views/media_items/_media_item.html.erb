<div id="<%= dom_id(media_item) %>" class="bg-white rounded-lg shadow-lg overflow-hidden flex hover:shadow-2xl hover:-translate-y-1 transition-all duration-300">
  
  <div class="w-1/3 flex-shrink-0">
    <% if media_item.cover_image.attached? %>
      <%= image_tag media_item.cover_image.variant(resize_to_fill: [400, 600]), class: "w-full h-full object-cover" %>
    <% else %>
      <div class="w-full h-full bg-gray-200 flex items-center justify-center p-2 text-center">
        <span class="text-gray-400 text-xs ml-2">No Image</span>
      </div>
    <% end %>
  </div>

  <div class="w-2/3 p-4 flex flex-col justify-between">

    <div>
      <p class="text-sm font-semibold text-indigo-600 uppercase tracking-wider"><%= media_item.category.name %></p>
      <h2 class="text-xl font-bold text-gray-800 mt-1 truncate" title="<%= media_item.title %>">
        <%= link_to media_item.title, media_item, data: { turbo_frame: "_top" }, class: "hover:text-indigo-700" %>
      </h2>
      
      <div class="flex items-center flex-wrap gap-2 mt-2">
        <span class="inline-flex items-center rounded-full bg-blue-100 px-2 py-0.5 text-xs font-medium text-blue-800">
          <%= media_item.status %>
        </span>
        <% if media_item.rating.present? %>
          <span class="inline-flex items-center rounded-full bg-yellow-100 px-2 py-0.5 text-xs font-medium text-yellow-800">
            ⭐ <%= media_item.rating %> / 10
          </span>
        <% end %>
      </div>
      
      <p class="text-gray-600 text-sm leading-relaxed mt-3">
        <%= truncate(media_item.description, length: 80) %>
      </p>

      <% if media_item.chapters_read.present? %>
        <div class="mt-4">
          <div class="flex justify-between items-center text-xs font-medium text-gray-500">
            <span>Chapters</span>
            <div class="flex items-center gap-2">
              <%= button_to "-", decrement_chapter_media_item_path(media_item), method: :patch, class: "flex items-center justify-center h-5 w-5 rounded-full bg-gray-200 text-gray-600 hover:bg-gray-300 transition" %>

              <span>
                <%= media_item.chapters_read %> / <%= media_item.total_chapters.presence || '?' %>
              </span>

              <%= button_to "+", increment_chapter_media_item_path(media_item), method: :patch, class: "flex items-center justify-center h-5 w-5 rounded-full bg-gray-200 text-gray-600 hover:bg-gray-300 transition" %>
            </div>
          </div>
          <% progress = media_item.total_chapters.to_i > 0 ? (media_item.chapters_read.to_f / media_item.total_chapters.to_f) * 100 : 0 %>
          <div class="w-full bg-gray-200 rounded-full h-1.5 mt-1">
            <div class="bg-blue-600 h-1.5 rounded-full" style="width: <%= progress %>%"></div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
