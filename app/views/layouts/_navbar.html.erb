<nav class="bg-gray-900 shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      
      <div class="flex items-center">
        <%= link_to "OtakuSen", profile_path(1), class: "text-white text-2xl font-bold tracking-tight" %>
        
        <div class="hidden md:block">
          <div class="ml-10 flex items-baseline space-x-4">
            <% if user_signed_in? %>
              <%= link_to "My Collection", media_items_path, class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
              <%= link_to "Dashboard", dashboard_path, class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="flex-1 flex justify-center px-2 lg:ml-6 lg:justify-end">
        <%= form_with(url: media_items_path, method: :get, 
                      class: "max-w-lg w-full lg:max-w-xs",
                      data: { 
                        controller: "search-form", 
                        turbo_frame: "results" 
                      }) do |form| %>

          <label for="search" class="sr-only">Search</label>
          <div class="relative text-gray-400 focus-within:text-gray-200">
            <div class="pointer-events-none absolute inset-y-0 left-0 pl-3 flex items-center">
              <svg class="h-5 w-5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M9 3.5a5.5 5.5 0 100 11 5.5 5.5 0 000-11zM2 9a7 7 0 1112.452 4.391l3.328 3.329a.75.75 monolithic="true" 11-1.06 1.06l-3.329-3.328A7 7 0 012 9z" clip-rule="evenodd" />
              </svg>
            </div>

            <%= form.text_field :search, 
                  value: params[:search],
                  class: "block w-full bg-gray-700 border border-transparent rounded-md py-2 pl-10 pr-3 text-white leading-5 focus:outline-none focus:bg-white focus:border-white focus:ring-white focus:text-gray-900 sm:text-sm", 
                  placeholder: "Search live...",
                  data: { action: "input->search-form#search" } %>
          </div>
        <% end %>
      </div>
      
      <div class="hidden md:block">
        <div class="ml-4 flex items-center md:ml-6 space-x-4">
          <% if user_signed_in? %>
            <%= link_to "Edit Profile", edit_user_registration_path, class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
            
            <% if current_user.avatar.attached? %>
              <%= image_tag current_user.avatar.variant(resize_to_fill: [32, 32]), class: "h-8 w-8 rounded-full" %>
            <% else %>
              <div class="h-8 w-8 rounded-full bg-gray-700 flex items-center justify-center text-gray-400"></div>
            <% end %>

            <%= button_to "Log out", destroy_user_session_path, method: :delete, class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
          <% else %>
            <%= link_to "Sign up", new_user_registration_path, class: "bg-indigo-600 text-white px-3 py-2 rounded-md text-sm font-semibold hover:bg-indigo-500" %>
            <%= link_to "Log in", new_user_session_path, class: "text-gray-300 hover:bg-gray-700 hover:text-white px-3 py-2 rounded-md text-sm font-medium" %>
          <% end %>
        </div>
      </div>

    </div>
  </div>
</nav>
