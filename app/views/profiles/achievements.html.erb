<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="mb-8">
    <h1 class="text-3xl font-bold tracking-tight text-base-content">Achievements for <%= @user.username %></h1>
    <%= link_to "← Back to Profile", profile_path(@user), class: "link link-hover text-sm mt-1" %>
  </div>

  <% if @achievements.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
      <% @achievements.each do |achievement| %>
        <div class="tooltip" data-tip="<%= achievement.description %>">
          <div class="card bg-base-100 p-4 flex flex-col items-center text-center shadow-lg hover:shadow-2xl transition-shadow">
            <div class="text-primary"><%= icon achievement.icon_name, class: "w-10 h-10" %></div>
            <span class="text-sm font-semibold mt-2"><%= achievement.display_name %></span>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-lg p-16 bg-base-100 text-center shadow-md">
      <p class="text-base-content/70">This user hasn't earned any achievements yet.</p>
    </div>
  <% end %>
</div>
