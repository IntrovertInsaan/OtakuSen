<div class="max-w-5xl mx-auto px-4 py-6">
  <!-- Thread Header -->
  <div class="flex items-center justify-between mb-6">
    <div>
      <div class="flex items-center gap-2 mb-1">
        <%= link_to forum_threads_path, class: "btn btn-ghost btn-sm btn-circle" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
          </svg>
        <% end %>
        <h1 class="text-2xl font-bold"><%= @forum_thread.title %></h1>
      </div>
      <p class="text-sm opacity-70">
        Started by <%= @forum_thread.user&.username || "[Deleted User]" %> • <%= time_ago_in_words(@forum_thread.created_at) %> ago
      </p>
    </div>
  </div>

  <!-- Messages Area -->
  <div class="bg-base-200 rounded-box">
    <div id="forum_posts" class="p-4 space-y-4 max-h-[calc(100vh-20rem)] min-h-[300px] overflow-y-auto" 
         data-controller="chat-scroll"
         data-chat-scroll-behavior-value="smooth">
      <%= turbo_stream_from @forum_thread, "forum_posts" %>
      <%= render @forum_thread.forum_posts.where.not(id: nil), current_user: current_user %>
    </div>

    <!-- Reply Form -->
    <div class="border-t border-base-300 p-4">
      <%= form_with model: [@forum_thread, ForumPost.new], 
                    class: "space-y-3", 
                    data: { 
                      controller: "reset-form", 
                      action: "turbo:submit-end->reset-form#reset"
                    } do |f| %>
        <%= f.rich_text_area :content,
            class: "textarea textarea-bordered bg-base-100 w-full min-h-[100px]",
            placeholder: "Type your message..." %>
        <div class="flex justify-end">
          <%= f.submit "Send", class: "btn btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
