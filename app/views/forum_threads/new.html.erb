<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <h1 class="text-3xl font-bold text-base-content mb-8">Start a New Discussion</h1>
  <%= form_with(model: @thread) do |f| %>
    <div class="space-y-6">
      <div class="form-control">
        <%= f.label :title, class: "label" %><br>
        <%= f.text_field :title, class: "input input-bordered" %>
      </div>
      <%= f.fields_for :forum_posts do |post_form| %>
        <div class="form-control">
          <%= post_form.label :content, "Your first post", class: "label" %>
          <%= post_form.rich_text_area :content, class: "textarea textarea-bordered w-full h-64" %>
        </div>
      <% end %>
      <div class="card-actions justify-end">
        <%= link_to "Cancel", forum_threads_path, class: "btn btn-ghost" %>
        <%= f.submit "Start Discussion", class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>
</div>
